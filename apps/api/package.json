{
  "name": "@pulso/api",
  "version": "0.1.0",
  "private": true,
  "description": "API do Pulso: carrega dados, chama o core e persiste. Nenhuma conta financeira aqui.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "db": "tsx scripts/dev-db.ts",
    "seed": "tsx scripts/seed-demo.ts",
    "promote-admin": "tsx scripts/promote-admin.ts",
    "migrate": "tsx src/migrate.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.1",
    "@fastify/cors": "^11.3.0",
    "@pulso/core": "workspace:*",
    "fastify": "^5.10.0",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@pulso/fixtures": "workspace:*",
    "@types/node": "^26.1.1",
    "embedded-postgres": "17.10.0-beta.17",
    "tsx": "^4.23.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
