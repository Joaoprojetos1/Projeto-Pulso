# Conexão com o Postgres. Para subir um banco local sem instalar nada: pnpm db
# Na nuvem, use a string do Neon (SSL liga sozinho para host que não é local).
DATABASE_URL=postgres://pulso:pulso@localhost:5433/pulso
PORT=3000
# Endereço em que o servidor escuta. Local: 127.0.0.1. Na nuvem (Render): 0.0.0.0
# HOST=127.0.0.1

# Chave da API da Anthropic (console.anthropic.com). OPCIONAL:
# sem ela, os alertas usam o texto padrão determinístico — tudo funciona.
# ANTHROPIC_API_KEY=sk-ant-...
# Modelo usado para redigir os alertas (padrão: claude-opus-4-8)
# PULSO_AI_MODEL=claude-opus-4-8
