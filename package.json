{
  "name": "pulso",
  "private": true,
  "packageManager": "pnpm@11.13.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "app": "pnpm --filter @pulso/mobile start",
    "api": "pnpm --filter @pulso/api dev",
    "db": "pnpm --filter @pulso/api db",
    "seed": "pnpm --filter @pulso/api seed"
  }
}
